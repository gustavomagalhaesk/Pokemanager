<div class="container mt-5">
  <% content_for :title, "Cadastrar Novo Item" %>

  <div class="row justify-content-center">
    <div class="col-md-6">
      
      <div class="card shadow border-0 overflow-hidden">
        
        <div class="card-header bg-success text-white text-center py-3">
          <h1 class="h3 mb-0">
            Novo Item para a Loja
          </h1>
        </div>

        <div class="card-body p-4">
          <div class="text-center mb-4 text-muted small">
            <p>Preencha os detalhes abaixo para disponibilizar um novo produto na PokeShop.</p>
          </div>

          <%= render "form", item: @item %>
        </div>

      </div>

      <div class="text-center mt-3 opacity-25">
        <i class="bi bi-shop fs-1"></i>
      </div>

    </div>
  </div>
</div>