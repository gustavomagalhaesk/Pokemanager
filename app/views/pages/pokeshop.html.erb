<div class="container mt-4">
  <div class="text-white p-4 rounded shadow-sm mb-4" style="background-image: url('/body_bg.png'); background-image: repeat; background-position: center;">
    <div class="d-flex justify-content-between align-items-center">
      <div>
        <h2 class="mb-0 text-info fw-bold"><i class="bi bi-shop me-2"></i>PokeShop</h2>
      </div>
      
      <div class="d-flex gap-2">
        <div class="dropdown">
          <button class="btn btn-outline-info fw-bold shadow-sm" data-bs-toggle="dropdown">
            Moeda
          </button>
          <ul class="dropdown-menu">
            <li><a class="dropdown-item" href="/pokeshop/?coin=dolar">$ - Dolar</a></li>
            <li><a class="dropdown-item" href="/pokeshop/?coin=real">R$ - Real</a></li>
            <li><a class="dropdown-item" href="/pokeshop/?coin=iene">¥ - Iene</a></li>
          </ul>
        </div>
        <div>
          <%= link_to new_item_path, class: "btn btn-outline-success fw-bold shadow-sm" do %>
            <i class="bi bi-plus-lg"></i> Adicionar Item
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div class="row row-cols-1 row-cols-md-4 g-4">
    <% @items.each do |item| %>
      <div class="col">
        <div class="card h-100 shadow-sm border-0 text-center position-relative">
          
          <div class="position-absolute top-0 end-0 p-2 d-flex gap-1" style="z-index: 10;">
            <%= link_to edit_item_path(item), class: "btn btn-light btn-sm shadow-sm border text-primary", title: "Editar" do %>
              <i class="bi bi-pencil-fill"></i>
            <% end %>
            
            <%= button_to item, method: :delete, 
                data: { confirm: "Tem certeza?" }, 
                class: "btn btn-light btn-sm shadow-sm border text-danger", 
                title: "Excluir" do %>
              <i class="bi bi-trash-fill"></i>
            <% end %>
          </div>

          <div class="p-3 bg-light border-bottom">
            <img src="<%= item.url_image %>" style="height: 80px; object-fit: contain;">
          </div>
          
          <div class="card-body">
            <h6 class="fw-bold mb-1"><%= item.name %></h6>
              <p class="text-success fw-bold mb-0">
              <%= convert_price(item.price, params[:coin]) %>
            </p>
          </div>
          
          <div class="card-footer bg-white border-0 pb-3">
            <%= link_to "Comprar", new_inventory_path(item_id: item.id), class: "btn btn-primary btn-sm w-100 fw-bold" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>