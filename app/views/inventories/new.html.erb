<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card shadow border-0">
        <div class="card-header bg-info text-white text-center py-3">
          <h1 class="h3 mb-0">Finalizar Compra</h1>
        </div>

        <div class="card-body p-4 text-center">
          <div class="mb-4">
            <img src="<%= @item.url_image %>" class="rounded-circle border bg-light p-2 mb-2" style="width: 100px; height: 100px;">
            <h4 class="fw-bold"><%= @item.name %></h4>
            <h3 class="text-success fw-bold">$<%= @item.price %></h3>
          </div>

            <%= form_with(model: @inventory, local: true) do |f| %>
            
              <%= f.hidden_field :item_id, value: @item.id %>

              <div class="mb-3 text-start">
                <%= f.label :trainer_id, "Quem está comprando?", class: "form-label fw-bold" %>
                <%= f.collection_select :trainer_id, Trainer.all, :id, :name, 
                    { prompt: "Selecione o Treinador" }, 
                    { class: "form-select form-select-lg", required: true } %>
              </div>

              <div class="mb-4 text-start">
                <%= f.label :quantity, "Quantidade", class: "form-label fw-bold" %>
                <%= f.number_field :quantity, value: 1, min: 1, class: "form-control form-control-lg", required: true %>
              </div>

              <div class="d-grid gap-2">
                <%= f.submit "Confirmar Pagamento", class: "btn btn-success btn-lg shadow-sm" %>
                <%= link_to "Cancelar", pokeshop_path, class: "btn btn-outline-secondary" %>
              </div>
<%# ... %>
            <% end %>
        </div>
        </div>
        <div class="text-center mt-3 opacity-25">
            <i class="bi bi-shop fs-1"></i>
        </div>

        </div>
    </div>
</div>